# Copy to .env and adjust (never commit real secrets).

# Required for production sessions / CSRF
FLASK_SECRET_KEY=replace-with-long-random-string

# Optional: on first DB init, seed one manager row (email + password = MANAGER_DASHBOARD_PASSWORD, hashed).
# Omit to skip; otherwise use /register or insert into managers manually.
# PRIMARY_OWNER_MANAGER_EMAIL=you@yourorg.com

# LPO/SM dashboard secret — same access-code sign-in and privileges as manager, but must be a different value.
# Leave unset or empty to hide the LPO/SM card until you configure it.
# LPO_SM_DASHBOARD_PASSWORD=your-lpo-sm-secret

# SQLite path (default: ./data/team_tracker.db). On Windows use forward slashes in .env so \t in \team_... is not read as a tab.
# TEAM_TRACKER_DB_PATH=C:/path/to/team_tracker.db

# Auto-backup SQLite while Flask is running: copy DB to ./Backup/ every N hours (SQLite backup API). Default N=2. Set to 0 to disable.
# TEAM_TRACKER_DB_BACKUP_INTERVAL_HOURS=2
# TEAM_TRACKER_DB_BACKUP_KEEP=30

# Set to 1 in real deployments. When set, employee "dev console" OTP is never auto-enabled without explicit PORTAL_OTP_DEV_CONSOLE=1.
# TEAM_TRACKER_PRODUCTION=1

# Microsoft / Azure AD (employee portal at /). Optional if you use email OTP instead.
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT_ID=organizations

# Email one-time codes (alternative to Microsoft). Requires SMTP + From; codes only for @nokia.com emails in nokia_portal_roster.py.
# PORTAL_OTP_SMTP_HOST=smtp.example.com
# PORTAL_OTP_SMTP_PORT=587
# PORTAL_OTP_SMTP_USER=
# PORTAL_OTP_SMTP_PASSWORD=
# PORTAL_OTP_FROM=leave-tracker@example.com
# PORTAL_OTP_FROM_NAME=TEAM MANAGEMENT PORTAL
# PORTAL_OTP_USE_TLS=true
# PORTAL_OTP_TTL_MINUTES=15
# Local dev only: OTP UI without SMTP — code in flash + server log. Never in production.
# PORTAL_OTP_DEV_CONSOLE=1
# Explicitly off (e.g. staging with TEAM_TRACKER_PRODUCTION=1 until OAuth is wired):
# PORTAL_OTP_DEV_CONSOLE=0
# Optional: seed demo sprint stickies (3 per roster member) on first DB init — set to 1 once for demos.
# PORTAL_SEED_DEMO_ITEMS=
# Rare: auto-apply employee portal Scrum changes without manager approval (default off; use only in trusted sandboxes).
# TEAM_TRACKER_PORTAL_AUTO_APPROVE=1

# FLASK_RUN_HOST=127.0.0.1
# FLASK_RUN_PORT=5000
# FLASK_DEBUG=1

# Optional: set to false to skip automatic winget install of Tesseract on Windows when it is missing
# TEAM_TRACKER_AUTO_TESSERACT=0

# Optional: full path if Tesseract is not on PATH (winget default: %LOCALAPPDATA%\Programs\Tesseract-OCR\tesseract.exe)
# TESSERACT_CMD=
